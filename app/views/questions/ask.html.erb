<div class="p-4">
  <h1>Stupid Coaching</h1>
  <p>Ask your coach something:</p>
  <form action="answer" data-turbo="false">
    <div class="d-inline-flex">
      <input type="text" name="question" class="form-control form-control-md" value="<%= params[:question] %>">
      <input type="submit" class="btn btn-primary" value="Ask">
    </div>
  </form>
</div>
